# tests/Dockerfile.server — includes replay-server for risk testing
FROM node:22-alpine AS ui-builder
WORKDIR /src/ui
COPY go/cmd/replay-server/ui/package*.json ./
RUN npm ci --prefer-offline
COPY go/cmd/replay-server/ui/ ./
RUN npm run build

FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go/ .
COPY --from=ui-builder /src/static ./cmd/replay-server/static
RUN go mod tidy
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /usr/local/bin/sudo-logserver ./cmd/server && \
    CGO_ENABLED=0 go build -ldflags="-s -w" -o /usr/local/bin/sudo-replay-server ./cmd/replay-server

# ---- Runtime stage ----
FROM alpine:latest
RUN apk add --no-cache ca-certificates coreutils grep curl netcat-openbsd apache2-utils procps

COPY --from=builder /usr/local/bin/sudo-logserver /usr/local/bin/sudo-logserver
COPY --from=builder /usr/local/bin/sudo-replay-server /usr/local/bin/sudo-replay-server
COPY go/cmd/replay-server/risk-rules.yaml /etc/sudo-logger/risk-rules.yaml

RUN mkdir -p /var/log/sudoreplay && chmod 777 /var/log/sudoreplay

EXPOSE 9876 8080
ENTRYPOINT ["/usr/local/bin/sudo-logserver"]
