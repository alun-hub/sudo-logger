## <summary>sudo-logger session recording plugin and agent</summary>

########################################
## <summary>
##   Allow a domain to connect to the sudo-logger-agent socket.
##   Used by sudo when the plugin calls connect_agent().
## </summary>
## <param name="domain">
##   <summary>Domain allowed to connect.</summary>
## </param>
#
interface(`sudo_logger_connect_agent',`
    gen_require(`
        type sudo_agent_t;
        type sudo_agent_var_run_t;
    ')
    allow $1 sudo_agent_var_run_t:dir search;
    allow $1 sudo_agent_var_run_t:sock_file write;
    allow $1 sudo_agent_t:unix_stream_socket connectto;
')

########################################
## <summary>
##   Allow a domain to load the sudo_logger plugin .so.
## </summary>
## <param name="domain">
##   <summary>Domain allowed to load the plugin.</summary>
## </param>
#
interface(`sudo_logger_load_plugin',`
    gen_require(`
        type sudo_logger_plugin_t;
    ')
    allow $1 sudo_logger_plugin_t:file { read open execute map getattr };
')
